{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "$comment": "Vercel Hobby caps cron to 1x/day. On Pro, raise: publish-scheduled to every 5m, sync-comments hourly, process-autonomy every 15m.",
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-comments",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/process-autonomy",
      "schedule": "45 6 * * *"
    }
  ]
}
