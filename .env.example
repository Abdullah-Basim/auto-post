# =====================================================================
# Autopost — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local.
# =====================================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase (REQUIRED) -----
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic Claude (REQUIRED for content generation) -----
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ----- Meta (Facebook + Instagram) — optional -----
# https://developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/auth/callback/meta

# ----- LinkedIn — optional -----
# https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/callback/linkedin

# ----- X (Twitter) — optional, requires paid Basic tier for posting -----
# https://developer.x.com/en/portal/dashboard
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/auth/callback/x

# ----- TikTok — optional -----
# https://developers.tiktok.com/apps
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/auth/callback/tiktok

# ----- Encryption key for credential at-rest encryption -----
# Generate: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=
